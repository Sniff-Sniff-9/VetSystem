@page "/dashboard"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="pt-2 px-4" 
              Style="background: linear-gradient(109.6deg, #E3F2FD 0%, #BBDEFB 100%); min-height:100vh;">

    <!-- ВЕРХНИЙ БАР С ПРИВЕТСТВИЕМ -->
    <MudCard Elevation="2" Class="d-flex justify-end align-center p-4 mt-1" Style="border-radius:16px;">
        <MudStack Direction="Row" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="ml-2">Иван Иванов</MudText>
        </MudStack>
    </MudCard>

    <!-- ОСНОВНАЯ КАРТОЧКА -->
    <MudCard Elevation="2" Class="p-6 mt-4" Style="border-radius:16px;">
        <MudStack Spacing="3">

            <!-- Кнопка создания записи -->
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium" StartIcon="@Icons.Material.Filled.Add" Class="mx-4 mt-4">
                Создать запись на приём
            </MudButton>

            <!-- Заголовок списка -->
            <MudText Typo="Typo.h6" Class="ml-6">Ближайшие записи</MudText>

            <!-- Список ближайших записей -->
            <MudPaper Elevation="0" Class="p-4 mx-4 mb-4" Style="background:#E3F2FD; border-radius:12px;">
                <MudList T="object" Dense="true">
                    <MudListItem T="object">
                        <MudListItemIcon><MudIcon Icon="@Icons.Material.Filled.Pets" /></MudListItemIcon>
                        <MudListItemText>
                            <div>Барсик — Вакцинация</div>
                            <div style="font-size:0.8rem; color:#555;">25 марта 2026, 14:00</div>
                        </MudListItemText>
                    </MudListItem>

                    <MudDivider />

                    <MudListItem T="object">
                        <MudListItemIcon><MudIcon Icon="@Icons.Material.Filled.Pets" /></MudListItemIcon>
                        <MudListItemText>
                            <div>Мурка — Чипирование</div>
                            <div style="font-size:0.8rem; color:#555;">26 марта 2026, 10:00</div>
                        </MudListItemText>
                    </MudListItem>
                </MudList>
            </MudPaper>

        </MudStack>
    </MudCard>

</MudContainer>
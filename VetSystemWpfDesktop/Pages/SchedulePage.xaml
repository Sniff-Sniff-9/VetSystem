<Page x:Class="VetSystemWpfDesktop.Pages.SchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local ="clr-namespace:VetSystemWpfDesktop.Converters"
      Background="#E3F2FD"
      Title="Расписание">
    <Page.Resources>
        <local:WorkdayTimeConverter x:Key="WorkdayTimeConverter"></local:WorkdayTimeConverter>
    </Page.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="8">
            <materialDesign:PackIcon Kind="Schedule" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Расписание" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>
        <Grid Margin="12" Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ КОЛОНКА -->
            <materialDesign:Card Grid.Column="0"
                             Padding="16"
                             UniformCornerRadius="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <!-- Поиск -->
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <TextBox Height="36" Width="200" materialDesign:HintAssist.Hint="Поиск..." Margin="0,0,0,10"/>
                    </StackPanel>

                    <!-- Список врачей -->
                    <ListView x:Name="DoctorsList"
                          BorderThickness="0"
                          Grid.Row="1"
                          HorizontalContentAlignment="Stretch" SelectionChanged="DoctorsList_SelectionChanged">

                        <ListView.ItemTemplate>

                            <DataTemplate>

                                <Border Padding="8">

                                    <StackPanel Orientation="Horizontal">

                                        <materialDesign:PackIcon
                                        Kind="Doctor"
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,6,0"
                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LastName}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding FirstName}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding MiddleName}"/>
                                        </StackPanel>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                </Grid>

            </materialDesign:Card>

            <!-- ПРАВАЯ КОЛОНКА -->

            <materialDesign:Card Grid.Column="2" Padding="28" UniformCornerRadius="20" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Text="Шаблонное расписание" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <!-- День недели -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Начало рабочего дня -->
                                <ColumnDefinition Width="30"/>
                                <!-- тире -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Конец рабочего дня -->
                                <ColumnDefinition Width="40"/>
                                <!-- отступ между блоками -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Начало обеда -->
                                <ColumnDefinition Width="30"/>
                                <!-- тире -->
                                <ColumnDefinition Width="1.5*"/>
                                <!-- Конец обеда -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="" 
                                       VerticalAlignment="Center" 
                                       FontWeight="SemiBold" 
                                       FontSize="15"/>

                            <StackPanel Grid.Column="1" 
                            Grid.ColumnSpan="3" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="Clock" 
                                             Width="20" 
                                             Height="20" 
                                             Margin="0,0,8,0"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                <TextBlock Text="Рабочее время" 
                               FontWeight="SemiBold" 
                               FontSize="15"/>
                            </StackPanel>

                            <!-- Обеденное время + иконка слева -->
                            <StackPanel Grid.Column="5" 
                            Grid.ColumnSpan="3" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="Restaurant" 
                                             Width="20" 
                                             Height="20" 
                                             Margin="0,0,8,0"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                <TextBlock Text="Обеденное время" 
                               FontWeight="SemiBold" 
                               FontSize="15"/>
                            </StackPanel>
                        </Grid>

                        <!-- СПИСОК РАСПИСАНИЯ (исправленная сетка в шаблоне) -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="ScheduleList" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" Margin="0,4,0,4" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <!-- День недели -->
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <!-- Начало рабочего дня -->
                                                    <ColumnDefinition Width="30"/>
                                                    <!-- тире -->
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <!-- Конец рабочего дня -->
                                                    <ColumnDefinition Width="40"/>
                                                    <!-- отступ -->
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <!-- Начало обеда -->
                                                    <ColumnDefinition Width="30"/>
                                                    <!-- тире -->
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <!-- Конец обеда -->
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                       Text="{Binding DayOfWeek}" 
                       VerticalAlignment="Center" 
                       FontWeight="SemiBold" 
                       FontSize="15"/>

                                                <TextBox Grid.Column="1" 
                     Height="36" 
                     FontSize="14" 
                     Text="{Binding StartTime, Converter={StaticResource WorkdayTimeConverter}}" 
                     materialDesign:HintAssist.Hint="08:00" 
                     IsReadOnly="True"/>

                                                <TextBlock Grid.Column="2" 
                       Text="-" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       FontSize="24"/>

                                                <TextBox Grid.Column="3" 
                     Height="36" 
                     FontSize="14" 
                     Text="{Binding EndTime, Converter={StaticResource WorkdayTimeConverter}}" 
                     materialDesign:HintAssist.Hint="17:00" 
                     IsReadOnly="True"/>

                                                <!-- пустая колонка-отступ -->

                                                <TextBox Grid.Column="5" 
                     Height="36" 
                     FontSize="14" 
                     Text="{Binding LunchStart, Converter={StaticResource WorkdayTimeConverter}}" 
                     materialDesign:HintAssist.Hint="12:00" 
                     IsReadOnly="True"/>

                                                <TextBlock Grid.Column="6" 
                       Text="-" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       FontSize="24"/>

                                                <TextBox Grid.Column="7" 
                     Height="36" 
                     FontSize="14" 
                     Text="{Binding LunchEnd, Converter={StaticResource WorkdayTimeConverter}}" 
                     materialDesign:HintAssist.Hint="13:00" 
                     IsReadOnly="True"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- Кнопки (оставлены без изменений) -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" Foreground="White" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Редактировать шаблон" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Добавить исключение" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</Page>
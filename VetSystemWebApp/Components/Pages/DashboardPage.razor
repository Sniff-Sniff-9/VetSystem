@page "/dashboard"
@using MudBlazor
@using VetSystemModels.Dto.Appointment
@inject Services.AppointmentsService AppointmentsService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.False" Class="pt-2 px-4" 
              Style="background: linear-gradient(109.6deg, #E3F2FD 0%, #BBDEFB 100%); min-height:100vh;">

    <!-- ВЕРХНИЙ БАР С ПРИВЕТСТВИЕМ -->
    <MudCard Elevation="2" Class="d-flex justify-end align-center p-4 mt-1" Style="border-radius:16px;">
        <MudStack Direction="Row" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="ml-2">Иван Иванов</MudText>
        </MudStack>
    </MudCard>

    <!-- ОСНОВНАЯ КАРТОЧКА -->
    <MudCard Elevation="2" Class="p-6 mt-4" Style="border-radius:16px;">
        <MudStack Spacing="3">

            <!-- Кнопка создания записи -->
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium" StartIcon="@Icons.Material.Filled.Add" Class="mx-4 mt-4">
                Создать запись на приём
            </MudButton>

            <!-- Заголовок списка -->
            <MudText Typo="Typo.h6" Class="ml-6">Ближайшие записи</MudText>

            <!-- Список ближайших записей -->
            <MudPaper Elevation="0" Class="p-4 mx-4 mb-4" Style="background:#E3F2FD; border-radius:12px;">
                @if (!_isClient)
                {
                    <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Info">Загрузка...</MudText>
                }
                else if (Appointments.Count == 0)
                {
                    <MudText Typo="Typo.h6" Class="ml-6" Color="Color.Info" Align="Align.Center">Нет записей.</MudText>
                }
                else
                {
                    <MudList T="AppointmentDto" Dense="true">
                        @foreach (var appointment in Appointments)
                        {
                            <MudListItem T="AppointmentDto">
                                <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                <div>@appointment.PetName — @appointment.ServiceName</div>
                                <div style="font-size:0.8rem; color:#555;">
                                    @appointment.AppointmentDate.ToString("dd MMMM yyyy")
                                </div>
                                <div>@appointment.SсheduleTimeStart — @appointment.SсheduleTimeEnd</div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                }
            </MudPaper>

        </MudStack>
    </MudCard>

</MudContainer>

@code {
    private List<AppointmentDto> Appointments = new();
    private bool _isClient = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isClient = true; // включаем "Загрузка..."
            StateHasChanged();

            var token = await JS.InvokeAsync<string>("eval",
                "document.cookie.split('; ').find(c => c.startsWith('jwtToken=')).split('=')[1] || ''");

            if (!string.IsNullOrEmpty(token))
            {
                try
                {
                    Appointments = await AppointmentsService.GetAppointmentsByClientIdAsync(token);
                }
                catch (Exception ex)
                {
                    Console.WriteLine(ex.Message); // логируем ошибки 401
                }
            }

            StateHasChanged();
        }
    }

}
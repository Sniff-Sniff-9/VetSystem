@inherits LayoutComponentBase
@using MudBlazor
@inject IJSRuntime JS
@inject NavigationManager Navigation
@using VetSystemWebApplication.Components

<MudThemeProvider Theme="@MyTheme" />
<MudDialogProvider />
<MudSnackbarProvider Style="@(IsMobile ? "z-index:1600; padding-top: 64px" : "z-index:1600;")" />
<MudPopoverProvider />

<MudLayout Style="background: linear-gradient(109.6deg, #E3F2FD 0%, #BBDEFB 100%); min-height:100vh;">

    <!-- AppBar только на мобильном -->
    @if (IsMobile)
    {
        <MudAppBar Elevation="4" Class="d-flex align-center px-4" Style="background:#03A9F4; color:white; z-index:1400;">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           OnClick="@ToggleDrawer" />
            <MudText Typo="Typo.h6" Class="ml-2">Ветеринарная Система</MudText>
        </MudAppBar>
    }

    <!-- SideMenu -->

    
        <SideMenu @bind-Open="_drawerOpen"
                  DrawerVariant="@DrawerVariant"
                  IsMobile="@IsMobile" />
 


    <!-- Main Content -->
    <MudMainContent Style="@MainContentStyle">
        @Body
    </MudMainContent>

</MudLayout>

@code {
    private MudTheme MyTheme => Themes.VetSystemTheme.Default;

    private bool _drawerOpen = true;

    private int _windowWidth = 1024;

    private bool IsMobile => _windowWidth < 768;

    private DrawerVariant DrawerVariant => IsMobile ? DrawerVariant.Temporary : DrawerVariant.Persistent;

    private string MainContentStyle =>
        $"min-height:100vh; " +
        $"padding:16px; " +
        $"padding-top:{(IsMobile ? "84px" : "0")}; " +
        $"transition: margin 0.3s;";

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    [JSInvokable]
    public void UpdateWidth(int width)
    {
        _windowWidth = width;

        // Десктоп — открыто, мобильный — закрыто
        _drawerOpen = !IsMobile;

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var dotRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("resizeObserver.register", dotRef);

    
            _drawerOpen = !IsMobile;

            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (IsMobile)
        {
            _drawerOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
<MudDrawer Open="@Open" OpenChanged="@OnDrawerChanged"
           Variant="@(IsMobile ? DrawerVariant.Temporary : DrawerVariant.Persistent)"
           Anchor="Anchor.Left"
           Elevation="4"
           Overlay="@IsMobile"
           ClipMode="DrawerClipMode.Never"
           Breakpoint="Breakpoint.None"
           Class="mud-width-250 d-flex flex-column justify-between"
           Style="z-index:1500;">

    <!-- Верхняя часть -->
    <div class="d-flex flex-column align-center mt-4 mb-3 px-3">

        <MudIcon Icon="@Icons.Material.Filled.Pets"
                 Size="Size.Large"
                 Color="Color.Primary"
                 Style="width:72px;height:72px;" />

        <MudText Typo="Typo.h6"
                 Align="Align.Center"
                 Color="Color.Primary"
                 Style="font-weight:700; font-size:1.1rem;">
            Ветеринарная
        </MudText>

        <MudText Typo="Typo.h6"
                 Align="Align.Center"
                 Color="Color.Primary"
                 Style="font-weight:700; font-size:1.1rem;">
            Система
        </MudText>

        <MudDivider Class="my-3" />
    </div>

    <!-- Меню -->
    <MudNavMenu Class="flex-grow-1 px-2">

        <MudNavLink Href="/dashboard"
                    Icon="@Icons.Material.Filled.Home"
                    OnClick="@OnLinkClick">
            Главная
        </MudNavLink>

        <MudDivider Class="my-1" />

        <MudNavLink Href="/appointments"
                    Icon="@Icons.Material.Filled.ListAlt"
                    OnClick="@OnLinkClick">
            Записи
        </MudNavLink>

        <MudDivider Class="my-1" />

        <MudNavLink Href="/pets"
                    Icon="@Icons.Material.Filled.Pets"
                    OnClick="@OnLinkClick">
            Питомцы
        </MudNavLink>

        <MudDivider Class="my-1" />

        <MudNavLink Href="/profile"
                    Icon="@Icons.Material.Filled.Person"
                    OnClick="@OnLinkClick">
            Профиль
        </MudNavLink>

        <MudDivider Class="my-1" />

        <MudNavLink Href="/"
                    Icon="@Icons.Material.Filled.ExitToApp"
                    OnClick="@OnLinkClick">
            Выход
        </MudNavLink>

    </MudNavMenu>

</MudDrawer>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public DrawerVariant DrawerVariant { get; set; } = DrawerVariant.Persistent;
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool IsMobile { get; set; }

    private async Task OnLinkClick()
    {
        if (IsMobile)
            await OpenChanged.InvokeAsync(false);
    }

    private async Task OnDrawerChanged(bool value)
    {
        Open = value;
        await OpenChanged.InvokeAsync(value);
    }
}
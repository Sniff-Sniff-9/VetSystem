 <Window x:Class="VetSystemWpfDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Ветеринарная Система"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        MinWidth="900"
        MinHeight="550">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E3F2FD" Offset="0"/>
            <GradientStop Color="#BBDEFB" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="20,16">

                <materialDesign:PackIcon Kind="Paw"
                                         Width="48"
                                         Height="48"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                           Text="Ветеринарная "
                           Margin="10,0,0,0"/>

                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                           Text="Система"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0"
                                 Margin="12"
                                 Padding="10"
                                 UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">

                <DockPanel>

                    <TextBlock Text="Меню"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="10"
                               DockPanel.Dock="Top"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Dashboard_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboardOutline"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>

                            </Button>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Patients_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Dog"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Пациенты"/>
                                </StackPanel>

                            </Button>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Clients_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Account"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Клиенты"/>
                                </StackPanel>

                            </Button>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Appointments_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CalendarClock"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Приемы"/>
                                </StackPanel>

                            </Button>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Doctors_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Doctor"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Врачи"/>
                                </StackPanel>

                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Shifts_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ClockOutline"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Расписание"/>
                                </StackPanel>

                            </Button>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Services_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Pill"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Услуги"/>
                                </StackPanel>

                            </Button>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="6"
                                    Height="60"
                                    Click="Settings_Click">

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Settings"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Настройки"/>
                                </StackPanel>

                            </Button>

                        </StackPanel>

                    </ScrollViewer>

                </DockPanel>

            </materialDesign:Card>

            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <!-- USER BAR -->
                <materialDesign:Card Grid.Row="0"
                                     Margin="12,12,12,6"
                                     Padding="10"
                                     UniformCornerRadius="16"
                                     materialDesign:ElevationAssist.Elevation="Dp2">

                    <DockPanel>

                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="10,0">

                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Logout"
                                                         Margin="0,0,6,0"/>
                                <TextBlock Text="Выйти"/>
                            </StackPanel>

                        </Button>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <materialDesign:PackIcon Kind="AccountCircle"
                                                     Width="32"
                                                     Height="32"
                                                     Margin="5"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

                            <TextBlock Text="Администратор"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       Margin="8,0,0,0"
                                       FontWeight="SemiBold"/>

                        </StackPanel>

                    </DockPanel>

                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1"
                     Margin="12,6,12,12"
                     Padding="26"
                     UniformCornerRadius="16"
                     materialDesign:ElevationAssist.Elevation="Dp2">

                    <!-- Внутренняя карточка для имитации скругления -->
                    <materialDesign:Card Margin="4"
                         Padding="0"
                         UniformCornerRadius="14"
                         Background="#E3F2FD"
                         materialDesign:ElevationAssist.Elevation="Dp0">

                        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               Background="{DynamicResource MaterialDesign.Brush.Background}"/>

                    </materialDesign:Card>
                </materialDesign:Card>

            </Grid>

        </Grid>

    </Grid>

</Window>
<Page x:Class="VetSystemWpfDesktop.Pages.AppointmentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:VetSystemWpfDesktop.Converters"
      Background="#E3F2FD"
      Title="Записи на приём">
    <Page.Resources>

        <!-- CONVERTER -->
        <local:AppointmentNowConverter x:Key="AppointmentNowConverter"/>

        <!-- STATUS CHIP STYLE -->
        <Style x:Key="StatusChip" TargetType="Border">

            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="TextElement.Foreground" Value="#424242"/>

            <Style.Triggers>

                <!-- Завершен -->
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Завершен">
                    <Setter Property="Background" Value="#334CAF50"/>
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                    <Setter Property="TextElement.Foreground" Value="#2E7D32"/>
                </DataTrigger>

                <!-- Отменен -->
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Отменен">
                    <Setter Property="Background" Value="#33F44336"/>
                    <Setter Property="BorderBrush" Value="#F44336"/>
                    <Setter Property="TextElement.Foreground" Value="#C62828"/>
                </DataTrigger>

                <!-- В процессе -->
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="В процессе">
                    <Setter Property="Background" Value="#332196F3"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="TextElement.Foreground" Value="#1565C0"/>
                </DataTrigger>

                <!-- Запланирован -->
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Запланирован">
                    <Setter Property="Background" Value="#332196F3"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="TextElement.Foreground" Value="#1565C0"/>
                </DataTrigger>

                <!-- Ожидает -->
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Ожидает">
                    <Setter Property="Background" Value="#33FFC107"/>
                    <Setter Property="BorderBrush" Value="#FFC107"/>
                    <Setter Property="TextElement.Foreground" Value="#F57F17"/>
                </DataTrigger>

            </Style.Triggers>

        </Style>
    </Page.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="8">
            <materialDesign:PackIcon Kind="CalendarClock" Width="40" Height="40" Foreground="#FF03A9F4"/>
            <TextBlock Text="Приемы" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>

        <!-- STATISTICS -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <materialDesign:Card Margin="4" Padding="16" UniformCornerRadius="12">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarCheck" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="Всего записей" Margin="0,6" FontWeight="SemiBold"  HorizontalAlignment="Center"/>
                    <TextBlock Text="256" FontSize="22" FontWeight="Bold"  HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Grid.Column="1" Margin="4" Padding="16" UniformCornerRadius="12">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarPlus" Width="32" Height="32" Foreground="Green"  HorizontalAlignment="Center"/>
                    <TextBlock Text="Новые за месяц" Margin="0,6" FontWeight="SemiBold"  HorizontalAlignment="Center"/>
                    <TextBlock Text="18" FontSize="22" FontWeight="Bold"  HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- MAIN CARD -->
        <materialDesign:Card Grid.Row="2" Padding="18" UniformCornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOOLBAR -->
                <DockPanel Margin="0,0,0,14">
                    <!-- ADD BUTTON -->
                    <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignRaisedButton}" 
                            Foreground="White" Height="36" Click="AddAppointmentButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus"/>
                            <TextBlock Text="Создать запись" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- SEARCH AND FILTERS -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Search -->
                        <materialDesign:PackIcon Kind="Search" Width="24" Height="24" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <TextBox Width="200" Height="36" materialDesign:HintAssist.Hint="Поиск..."/>

                        <!-- Filters -->
                        <DatePicker Width="140" Height="36" materialDesign:HintAssist.Hint="С" Margin="10,0,0,0"/>
                        <DatePicker Width="140" Height="36" materialDesign:HintAssist.Hint="По" Margin="10,0,0,0"/>
                        <ComboBox Width="140" Height="36" materialDesign:HintAssist.Hint="Статус" Margin="10,0,0,0"/>
                        <ComboBox Width="140" Height="36" materialDesign:HintAssist.Hint="Врач" Margin="10,0,0,0"/>
                        <ComboBox Width="140" Height="36" materialDesign:HintAssist.Hint="Клиент" Margin="10,0,0,0"/>
                        <ComboBox Width="140" Height="36" materialDesign:HintAssist.Hint="Питомец" Margin="10,0,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- TABLE -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Margin="8,0,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Дата" FontWeight="SemiBold"/>
                        <TextBlock Text="Начало" Grid.Column="1" FontWeight="SemiBold"/>
                        <TextBlock Text="Конец" Grid.Column="2" FontWeight="SemiBold"/>
                        <TextBlock Text="Услуга" Grid.Column="3" FontWeight="SemiBold"/>
                        <TextBlock Text="Специалист" Grid.Column="4" FontWeight="SemiBold"/>
                        <TextBlock Text="Питомец" Grid.Column="5" FontWeight="SemiBold"/>
                        <TextBlock Text="Клиент" Grid.Column="6" FontWeight="SemiBold"/>
                        <TextBlock Text="Статус" Grid.Column="7" FontWeight="SemiBold" Margin="50,0,0,0"/>
                        <TextBlock Text="Цена" Grid.Column="8" FontWeight="SemiBold"/>
                        <TextBlock Text="Действия" Grid.Column="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- LIST -->
                    <ListView Grid.Row="1" x:Name="AppointmentsListView" BorderThickness="0" HorizontalContentAlignment="Stretch" materialDesign:ElevationAssist.Elevation="Dp0">
                        <ListView.ItemContainerStyle>

                            <Style TargetType="ListViewItem">

                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                                <Setter Property="Template">

                                    <Setter.Value>

                                        <ControlTemplate TargetType="ListViewItem">

                                            <Border x:Name="RowBorder"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="0,0,0,1"
                                                Background="Transparent">

                                                <ContentPresenter/>

                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <!-- HOVER -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBorder"
                                                        Property="Background"
                                                        Value="#F5F5F5"/>
                                                </Trigger>

                                                <!-- CURRENT APPOINTMENT -->
                                                <DataTrigger Value="True">

                                                    <DataTrigger.Binding>

                                                        <MultiBinding Converter="{StaticResource AppointmentNowConverter}">

                                                            <Binding Path="AppointmentDate"/>
                                                            <Binding Path="SсheduleTimeStart"/>
                                                            <Binding Path="SсheduleTimeEnd"/>

                                                        </MultiBinding>

                                                    </DataTrigger.Binding>

                                                    <Setter TargetName="RowBorder"
                                                        Property="Background"
                                                        Value="#E3F2FD"/>

                                                    <Setter TargetName="RowBorder"
                                                        Property="BorderBrush"
                                                        Value="#2196F3"/>

                                                    <Setter TargetName="RowBorder"
                                                        Property="BorderThickness"
                                                        Value="2"/>

                                                </DataTrigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                    </Setter.Value>

                                </Setter>

                            </Style>

                        </ListView.ItemContainerStyle>

                        <!-- ROW TEMPLATE -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <Grid Margin="8,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CalendarClock" Margin="0,0,6,0" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <TextBlock Text="{Binding AppointmentDate, StringFormat=dd.MM.yyyy}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding StartTime, StringFormat=HH:mm}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding EndTime, StringFormat=HH:mm}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ServiceName}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding EmployeeName}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding PetName}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="{Binding ClientName}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="7" 
                                                Style="{StaticResource StatusChip}"
                                                HorizontalAlignment="Left" Height="30" Margin="50,0,0,0">

                                            <TextBlock Text="{Binding AppointmentStatusName}"
                                                       Margin="4,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="8" Text="{Binding TotalPriceAtMoment, StringFormat=C}" VerticalAlignment="Center"/>

                                        <!-- ACTIONS -->
                                        <StackPanel Grid.Column="9" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Просмотреть">
                                                <materialDesign:PackIcon Kind="EyeOutline"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Редактировать">
                                                <materialDesign:PackIcon Kind="Pencil"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Удалить">
                                                <materialDesign:PackIcon Kind="Delete"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
<Page x:Class="VetSystemWpfDesktop.Pages.EmployeeSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:VetSystemWpfDesktop.Pages"
      xmlns:syncfusion="http://schemas.syncfusion.com/wpf"         
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#E3F2FD"
      Title="EmployeeSchedulePage"
      mc:Ignorable="d">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="8">
            <materialDesign:PackIcon Kind="Schedule" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Расписание" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>

        <Grid Margin="16" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка -->
            <Grid Grid.Column="0" Margin="8" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Календарь -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Calendar SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Grid.Row="0" Background="White"
                          SelectedDatesChanged="Calendar_SelectedDatesChanged"/>

                <!-- Карточка врача -->
                <materialDesign:Card Background="White" UniformCornerRadius="8" Grid.Row="1" Padding="12" Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- ФИО -->
                            <RowDefinition Height="Auto"/>
                            <!-- Специализация -->
                            <RowDefinition Height="*"/>
                            <!-- Пустое пространство / счётчик записей -->
                            <RowDefinition Height="Auto"/>
                            <!-- Кнопка Назад -->
                        </Grid.RowDefinitions>

                        <TextBlock Name="EmployeeFullName" FontSize="20" FontWeight="Bold" Margin="5,5,0,0" Grid.Row="0"/>
                        <TextBlock Text="{Binding SpecializationName}" FontSize="14" Foreground="Gray" Margin="5,5,0,0" Grid.Row="1"/>
                        <TextBlock Name="AppointmentsCountTextBlock" FontSize="14" Margin="5,5,0,0" Grid.Row="2" VerticalAlignment="Top"/>
                        <Button Name="CancelButton" Grid.Row="3" Content="Назад" Margin="0,12,0,0" 
                Style="{DynamicResource MaterialDesignOutlinedButton}"/>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- Правая колонка — SfScheduler -->
            <Grid Grid.Column="1" Margin="8,0,8,0">
                <Grid Grid.Column="1" Margin="8">
                    <local:DayScheduleView x:Name="ScheduleView"></local:DayScheduleView>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Page>
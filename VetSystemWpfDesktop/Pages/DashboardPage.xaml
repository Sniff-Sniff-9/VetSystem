<Page x:Class="VetSystemWpfDesktop.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#E3F2FD"
      Title="Панель управления">

    <Page.Resources>
        <!-- StatusChip как на AppointmentsPage -->
        <Style x:Key="StatusChip" TargetType="Border">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="TextElement.Foreground" Value="#424242"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid HorizontalAlignment="Center" MaxWidth="1200" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- KPI -->
                <RowDefinition Height="*"/>
                <!-- Main content -->
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <materialDesign:PackIcon Kind="ViewDashboard" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                <TextBlock Text="Панель управления" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            </StackPanel>

            <!-- KPI CARDS -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Left">
                <materialDesign:Card Margin="0,0,12,0" Padding="16" UniformCornerRadius="12" Width="220">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CurrencyRub" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <TextBlock Text="Доход за месяц" Margin="0,6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding MonthlyRevenue, StringFormat=C}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="0" Padding="16" UniformCornerRadius="12" Width="220">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ChartLine" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <TextBlock Text="График нагрузки" Margin="0,6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <Border Background="White" Height="50" Width="140" Margin="0,4">
                            <TextBlock Text="График" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Quick Access -->
                    <ColumnDefinition Width="*"/>
                    <!-- Upcoming -->
                    <ColumnDefinition Width="*"/>
                    <!-- Waiting -->
                </Grid.ColumnDefinitions>

                <!-- QUICK ACCESS -->
                <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,12,0">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Width="140" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Plus" Foreground="White"/>
                            <TextBlock Text="Запись" Margin="6,0,0,0" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Width="140" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountPlus" Foreground="White"/>
                            <TextBlock Text="Клиент" Margin="6,0,0,0" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Width="140" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Dog" Foreground="White"/>
                            <TextBlock Text="Питомец" Margin="6,0,0,0" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- БЛИЖАЙШИЕ ЗАПИСИ -->
                <materialDesign:Card Grid.Column="1" Padding="16" UniformCornerRadius="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Ближайшие приёмы" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ListView ItemsSource="{Binding UpcomingAppointments}" BorderThickness="0" HorizontalContentAlignment="Stretch">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="Bd" Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding AppointmentDate, StringFormat=dd.MM.yyyy}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ScheduleTimeStart, StringFormat=HH:mm}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ScheduleTimeEnd, StringFormat=HH:mm}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ServiceName}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding PetName}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding ClientName}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="6" Style="{StaticResource StatusChip}" HorizontalAlignment="Left" Height="30">
                                            <TextBlock Text="{Binding AppointmentStatusName}" Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="7" Text="{Binding TotalPriceAtMoment, StringFormat=C}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ОЖИДАЮТ ПОДТВЕРЖДЕНИЯ -->
                <materialDesign:Card Grid.Column="2" Padding="16" UniformCornerRadius="16">
                    <StackPanel>
                        <TextBlock Text="Ожидают подтверждения" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ListView ItemsSource="{Binding WaitingAppointments}" BorderThickness="0" HorizontalContentAlignment="Stretch">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="Bd" Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
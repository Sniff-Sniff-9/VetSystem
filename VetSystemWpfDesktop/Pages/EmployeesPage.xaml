<Page x:Class="VetSystemWpfDesktop.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VetSystemWpfDesktop.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" Background="#E3F2FD" Title="Специалисты">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="8">
            <materialDesign:PackIcon Kind="Doctor" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Специалисты" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>
        <!-- STATISTICS -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <materialDesign:Card Margin="4" Padding="16" UniformCornerRadius="12">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Doctor" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="Всего специалистов" Margin="0,6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="85" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
        <!-- MAIN CARD -->
        <materialDesign:Card Grid.Row="2" Padding="18" UniformCornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- TOOLBAR -->
                <DockPanel Margin="0,0,0,14">
                    <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignRaisedButton}" Foreground="White" Height="36" Click="AddEmployeeButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus"/>
                            <TextBlock Text="Добавить специалиста" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- SEARCH -->
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Search" Width="24" Height="24" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <TextBox Width="200" Height="36" materialDesign:HintAssist.Hint="Поиск..."/>
                    </StackPanel>
                </DockPanel>
                <!-- CLIENT TABLE -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- HEADER -->
                    <Grid Margin="8,0,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Фамилия" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Имя" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Отчество" Grid.Column="2" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Специализация" Grid.Column="3" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Дата рождения" Grid.Column="4" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Телефон" Grid.Column="5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Действия" Grid.Column="6" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <!-- LIST -->
                    <ListView Grid.Row="1" x:Name="ClientsListView" BorderThickness="0" HorizontalContentAlignment="Stretch" materialDesign:ElevationAssist.Elevation="Dp0">
                        <!-- Hover строки -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd" Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <!-- ROW TEMPLATE -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <Grid Margin="8,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="250"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">

                                            <materialDesign:PackIcon Kind="Account"
                         Margin="0,0,6,0"
                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

                                            <TextBlock Text="{Binding LastName}"
           FontWeight="SemiBold" VerticalAlignment="Center"/>

                                        </StackPanel>
                                        <TextBlock Text="{Binding FirstName}" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding MiddleName}" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SpecializationName}" Grid.Column="3" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding BirthDate, StringFormat='dd.MM.yyyy'}" Grid.Column="4" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Phone}" Grid.Column="5" VerticalAlignment="Center"/>
                                        <!-- ACTIONS -->
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Просмотреть">
                                                <materialDesign:PackIcon Kind="EyeOutline"/>
                                            </Button>
                                            <Button  Style="{StaticResource MaterialDesignIconButton}" ToolTip="Редактировать">
                                                <materialDesign:PackIcon Kind="Pencil"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Расписание" Name="CheckEmpployeeSchedule" Click="CheckEmpployeeSchedule_Click">
                                                <materialDesign:PackIcon Kind="Schedule"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Удалить">
                                                <materialDesign:PackIcon Kind="Delete"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>

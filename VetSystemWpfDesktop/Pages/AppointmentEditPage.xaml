<Page x:Class="VetSystemWpfDesktop.Pages.AppointmentEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#E3F2FD"
      Title="Запись на прием">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="8,8,8,18">
            <materialDesign:PackIcon Kind="CalendarPlus" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Запись" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>

        <!-- MAIN CARD -->
        <ScrollViewer Grid.Row="1">

            <materialDesign:Card Padding="18" Margin="0,0,0,10" UniformCornerRadius="16" materialDesign:ElevationAssist.Elevation="Dp2">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ОСНОВНАЯ ИНФОРМАЦИЯ -->
                    <TextBlock Text="Основная информация" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- КЛИЕНТ -->
                        <materialDesign:Card Grid.Row="0" Grid.Column="0" Margin="8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Клиент" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <!--<StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>-->
                                    <TextBox x:Name="ClientSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." 
                                             TextChanged="ClientSearchTextBox_TextChanged"/>
                                <!--</StackPanel>-->
                                <ListBox x:Name="ClientsListBox" Height="120" SelectionChanged="ClientsListBox_SelectionChanged"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- ПИТОМЕЦ -->
                        <materialDesign:Card Grid.Row="0" Grid.Column="1" Margin="8" Padding="16" IsEnabled="False" x:Name="PetCard">
                            <StackPanel>
                                <TextBlock Text="Питомец" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="PetSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." TextChanged="PetSearchTextBox_TextChanged"/>
                                <ListBox x:Name="PetsListBox" Height="120" SelectionChanged="PetsListBox_SelectionChanged"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- УСЛУГА -->
                        <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="8" Padding="16" IsEnabled="False" x:Name="ServiceCard">
                            <StackPanel>
                                <TextBlock Text="Основная услуга" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="ServiceSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." TextChanged="ServiceSearchTextBox_TextChanged"/>
                                <ListBox x:Name="ServicesListBox" Height="120" SelectionChanged="ServicesListBox_SelectionChanged"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- ВРАЧ -->
                        <materialDesign:Card Grid.Row="1" Grid.Column="1" Margin="8" Padding="16" IsEnabled="False" x:Name="DoctorCard">
                            <StackPanel>
                                <TextBlock Text="Врач" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="DoctorSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." TextChanged="DoctorSearchTextBox_TextChanged"/>
                                <ListBox x:Name="DoctorsListBox" Height="120" SelectionChanged="DoctorsListBox_SelectionChanged"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- ДАТА И ОКНА -->
                        <materialDesign:Card Grid.Row="2" Grid.ColumnSpan="2" Margin="8" Padding="16" IsEnabled="False" x:Name="DateSlotCard">
                            <StackPanel>
                                <TextBlock Text="Дата и время" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <DatePicker x:Name="DatePicker" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                                <WrapPanel x:Name="SlotsPanel" Margin="0,12,0,0"/>
                                <TextBlock x:Name="SelectedSlotText" Margin="12,6,0,0" FontWeight="SemiBold"/>
                            </StackPanel>
                        </materialDesign:Card>

                    </Grid>

                    <!-- ДОП УСЛУГИ -->
                    <TextBlock Grid.Row="2" Text="Дополнительные услуги" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,16"/>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Height="36" HorizontalAlignment="Left" Click="AddServiceButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus"/>
                                <TextBlock Text="Добавить услугу" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <ListView Grid.Row="1" x:Name="AdditionalServicesListView" BorderThickness="0" HorizontalContentAlignment="Stretch" materialDesign:ElevationAssist.Elevation="Dp0" Margin="0,10,0,0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="6,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Иконка -->
                                            <materialDesign:PackIcon Grid.Column="0" Kind="Plus" Width="24" Height="24" Foreground="{StaticResource MaterialDesign.Brush.Primary}" VerticalAlignment="Center"/>

                                            <!-- Название услуги -->
                                            <TextBlock Grid.Column="1" Text="{Binding ServiceName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>

                                            <!-- Цена -->
                                            <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat=C}" VerticalAlignment="Center" FontWeight="Medium" Foreground="#FF1976D2"/>

                                            <!-- Кнопка удалить -->
                                            <Button Grid.Column="3" Style="{StaticResource MaterialDesignIconButton}" Click="RemoveServiceButton_Click" ToolTip="Удалить">
                                                <materialDesign:PackIcon Kind="Delete"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- ИТОГ -->
                    <Border Grid.Row="4" Margin="0,20,0,0" Padding="16" Background="#F5F5F5" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.ColumnSpan="2" Text="Итоговая стоимость:" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TotalPriceText" FontSize="22" FontWeight="Bold"  Text="$1000.0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- BUTTONS -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0" Width="120" Click="CancelButton_Click">Отмена</Button>
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" Foreground="White" Width="160" Name="SaveButton" Click="SaveButton_Click">Сохранить</Button>
                    </StackPanel>

                </Grid>
            </materialDesign:Card>
        </ScrollViewer>
    </Grid>

</Page>
<Page x:Class="VetSystemWpfDesktop.Pages.AppointmentEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Background="#E3F2FD"
      Title="Запись на прием">
    <Page.Resources>
        <Style x:Key="StatusChoiceChip"
       TargetType="RadioButton"
       BasedOn="{StaticResource MaterialDesignChoiceChipPrimaryRadioButton}">

            <Setter Property="Foreground" Value="#424242"/>

            <Style.Triggers>

                <!-- Ожидает -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Content" Value="Ожидает"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#FFC107"/>
                    <Setter Property="BorderBrush" Value="#FFC107"/>
                    <Setter Property="Foreground" Value="Black"/>
                </MultiTrigger>

                <!-- Запланирован -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Content" Value="Запланирован"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="Black"/>
                </MultiTrigger>

                <!-- В процессе -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Content" Value="В процессе"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="Black"/>
                </MultiTrigger>

                <!-- Завершен -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Content" Value="Завершен"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                    <Setter Property="Foreground" Value="Black"/>
                </MultiTrigger>

                <!-- Отменен -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Content" Value="Отменен"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#F44336"/>
                    <Setter Property="BorderBrush" Value="#F44336"/>
                    <Setter Property="Foreground" Value="Black"/>
                </MultiTrigger>

            </Style.Triggers>

        </Style>
    </Page.Resources>

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

    
        <StackPanel Orientation="Horizontal" Margin="8,8,8,18">
            <materialDesign:PackIcon Kind="CalendarPlus" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Запись на прием" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>

     
        <ScrollViewer Grid.Row="1">

            <materialDesign:Card Padding="18" Margin="0,0,0,10" UniformCornerRadius="16" materialDesign:ElevationAssist.Elevation="Dp2" Name="MainCard">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

          
                    <TextBlock Text="Основная информация" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                
                        <materialDesign:Card Grid.Row="0" Grid.Column="0" Margin="8" Padding="16" Name="ClientCard">
                            <StackPanel>
                                <TextBlock Text="Клиент" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="*"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                    <TextBox Grid.Column="1" x:Name="ClientSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." 
                                             TextChanged="ClientSearchTextBox_TextChanged"/>
                                </Grid>
                                <ListBox x:Name="ClientsListBox" Height="120" Margin="0,5,0,0"
                                         SelectionChanged="ClientsListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Account" Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                                     Margin="0,0,5,0"></materialDesign:PackIcon>
                                                <TextBlock Text="{Binding LastName}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding FirstName}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding MiddleName}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </materialDesign:Card>

                      
                        <materialDesign:Card Grid.Row="0" Grid.Column="1" IsEnabled="False"
                                             Margin="8" Padding="16"  x:Name="PetCard">
                            <StackPanel>
                                <TextBlock Text="Питомец" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="*"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                    <TextBox Grid.Column="1" x:Name="PetSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." 
             TextChanged="ClientSearchTextBox_TextChanged"/>
                                </Grid>
                                <ListBox x:Name="PetsListBox" Height="120" Margin="0,5,0,0" SelectionChanged="PetsListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Dog" Foreground="{StaticResource MaterialDesign.Brush.Primary}"
 Margin="0,0,5,0"></materialDesign:PackIcon>
                                                <TextBlock Text="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </materialDesign:Card>

                      
                        <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="8" Padding="16"  x:Name="ServiceCard">
                            <StackPanel>
                                <TextBlock Text="Основная услуга" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="*"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                    <TextBox Grid.Column="1" x:Name="ServiceSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." 
TextChanged="ServiceSearchTextBox_TextChanged"/>
                                </Grid>
                                <ListBox x:Name="ServicesListBox" Height="120" Margin="0,5,0,0" SelectionChanged="ServicesListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Pill" Foreground="{StaticResource MaterialDesign.Brush.Primary}"
 Margin="0,0,5,0"></materialDesign:PackIcon>
                                                <TextBlock Text="{Binding ServiceName}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </materialDesign:Card>

                  
                        <materialDesign:Card Grid.Row="1" Grid.Column="1" IsEnabled="False"
                                             Margin="8" Padding="16" x:Name="DoctorCard">
                            <StackPanel>
                                <TextBlock Text="Врач" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="*"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                    <TextBox Grid.Column="1" x:Name="EmployeeSearchTextBox" Height="36" materialDesign:HintAssist.Hint="Поиск..." 
TextChanged="DoctorSearchTextBox_TextChanged"/>
                                </Grid>
                                <ListBox x:Name="DoctorsListBox" Height="120" Margin="0,5,0,0" SelectionChanged="DoctorsListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Doctor" Foreground="{StaticResource MaterialDesign.Brush.Primary}"
 Margin="0,0,5,0"></materialDesign:PackIcon>
                                                <TextBlock Text="{Binding LastName}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding FirstName}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding MiddleName}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Row="2" Grid.ColumnSpan="2" Margin="8" Padding="16" x:Name="DateSlotCard">
                            <StackPanel>
                                <TextBlock Text="Статус записи"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"
                   FontSize="14"/>

                                <StackPanel Orientation="Horizontal" Margin="4,0,0,30" Name="StatusButtonStackPanel">

                                    <RadioButton Content="Ожидает"
                 GroupName="Status"
                 Style="{StaticResource StatusChoiceChip}" Tag="1"
                 Margin="0,0,8,0"/>

                                    <RadioButton Content="Запланирован"
                 GroupName="Status"
                 Style="{StaticResource StatusChoiceChip}" Tag="2"
                 Margin="0,0,8,0"/>

                                    <RadioButton Content="В процессе" Tag="3"
                 GroupName="Status"
                 Style="{StaticResource StatusChoiceChip}"
                 Margin="0,0,8,0"/>

                                    <RadioButton Content="Завершен"
                 GroupName="Status"
                 Style="{StaticResource StatusChoiceChip}" Tag="4"
                 Margin="0,0,8,0"/>

                                    <RadioButton Content="Отменен" Tag="5"
                 GroupName="Status"
                 Style="{StaticResource StatusChoiceChip}"/>

                                </StackPanel>

                                <TextBlock Text="Дата" FontWeight="SemiBold" Margin="0,0,0,12" FontSize="14"/>
                                <DatePicker x:Name="DatePicker" SelectedDateChanged="DatePicker_SelectedDateChanged" Height="36"
                                            Margin="4,0,0,30" materialDesign:HintAssist.Hint="Выберите дату" />
                                <TextBlock Text="Время" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="14"/>
                                <WrapPanel x:Name="SlotsPanel" Margin="0,6,0,0"></WrapPanel>
                                <TextBlock x:Name="SelectedSlotText" Margin="12,6,0,20" Foreground="Gray" Text="Выберите дату или специалиста."
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>            
                            </StackPanel>
                        </materialDesign:Card>

                    </Grid>

    
                    <TextBlock Text="Дополнительные услуги" 
                               FontSize="19" 
                               FontWeight="SemiBold" 
                               Margin="4,32,0,16" Grid.Row="2"/>

                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                            HorizontalAlignment="Left" 
                            Height="40" 
                            Click="AddServiceButton_Click" Name="AddServiceButton" Grid.Row="3">
                        <StackPanel Orientation="Horizontal" >
                            <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"/>
                            <TextBlock Text="Добавить услугу" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    
                    <ListView x:Name="AdditionalServicesListView" 
                              Margin="0,12,0,0" 
                              BorderThickness="0" 
                              HorizontalContentAlignment="Stretch" Grid.Row="4">
                        <ListView.Style>
                            <Style TargetType="ListView">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListView">
                                                    <TextBlock Text="Нет дополнительных услуг."
                                                                Foreground="Gray"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Margin="0,10,0,20"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Style>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsMain}" Value="true">
                                        <Setter Property="IsEnabled" Value="False"></Setter>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                                <Border BorderBrush="#E0E0E0" 
                                        BorderThickness="0,0,0,1" 
                                        Padding="8,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>

                                        <materialDesign:PackIcon Grid.Column="0" 
                                                                 Kind="Plus" 
                                                                 Width="24" Height="24" 
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" 
                                                                 VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding ServiceName}" 
                                                   VerticalAlignment="Center" 
                                                   FontWeight="SemiBold" FontSize="14.5"/>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding PriceAtMoment, StringFormat='{}{0} ₽'}" 
                                                   VerticalAlignment="Center" 
                                                   FontWeight="Medium" 
                                                   Foreground="#FF1976D2"/>

                                        <Button Grid.Column="3" 
                                                Style="{StaticResource MaterialDesignIconButton}" 
                                                Width="32" Height="32"
                                                Click="RemoveServiceButton_Click" 
                                                ToolTip="Удалить">
                                            <materialDesign:PackIcon Kind="Delete"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

             
                    <Border Margin="0,28,0,0" 
                            Padding="20" 
                            Background="#F5F5F5" 
                            CornerRadius="12" Grid.Row="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Итоговая стоимость:" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       VerticalAlignment="Center"/>

                            <TextBlock x:Name="TotalPriceText" 
                                       Grid.Column="2" 
                                       Text="0 ₽" 
                                       FontSize="26" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0" Width="120" Click="CancelButton_Click">Отмена</Button>
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" Foreground="White" Width="160" 
                                Name="SaveButton" Click="SaveButton_Click">Сохранить</Button>
                    </StackPanel>

                </Grid>
            </materialDesign:Card>
        </ScrollViewer>
    </Grid>

</Page>
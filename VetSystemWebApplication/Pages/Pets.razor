@page "/pets"
@using MudBlazor
@using VetSystemModels.Dto.Pet
@inject Services.PetsService PetsService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False"
              Class="pt-2 px-3 px-md-6"
              Style="background: linear-gradient(109.6deg, #E3F2FD 0%, #BBDEFB 100%); min-height:100vh;">

    <MudCard Elevation="2" Class="mt-1" Style="border-radius:16px;">
        <MudStack Spacing="3">

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="mx-4 mt-4"
            OnClick="@AddPet">
                Добавить питомца
            </MudButton>

            <MudText Typo="Typo.h6" Class="ml-6">
                Ваши питомцы
            </MudText>

            <MudPaper Elevation="0"
                      Class="mx-4 mb-4 pa-2"
                      Style="background:#E3F2FD; border-radius:12px;">

                @if (isLoading)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                }
                else if (ClientPets.Count == 0)
                {
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="m-4">
                        Нет записей.
                    </MudText>
                }
                else
                {
                    <MudList T="PetDto" Dense="true">
                        @foreach (var p in ClientPets)
                        {
                            <MudListItem>
                                <MudCard Elevation="1"
                                         Outlined="false"
                                      
                                         Style="border-radius: 12px; overflow: hidden;">

                                        <MudCardContent Class="pa-4">
                                            <MudStack Spacing="2">

                                                <div class="d-flex align-center flex-wrap" style="min-width:0;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Pets"
                                                             Size="Size.Small"
                                                             Color="Color.Primary"
                                                             Class="mr-2 mb-1 mb-sm-0" />
                                                    <MudText Typo="Typo.h6"
                                                             Class="fw-semibold mb-0"
                                                             Style="white-space: normal; word-break: break-word; min-width:0;">
                                                        @p.Name
                                                    </MudText>
                                                </div>

                                                <!-- Вид и порода -->
                                                <div class="d-flex flex-wrap gap-3 mt-1">
                                                    <MudText Typo="Typo.subtitle1">
                                                        Вид: @p.SpeciesName
                                                    </MudText>
                                                    <MudText Typo="Typo.subtitle1">
                                                        Порода: @p.Breed
                                                    </MudText>
                                                </div>

                                                <!-- Дата рождения -->
                                                <div class="d-flex align-center mt-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Cake"
                                                             Size="Size.Small"
                                                             Color="Color.Default"
                                                             Class="mr-2" />
                                                    <MudText Size="Size.Small">
                                                        @p.BirthDate.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))
                                                    </MudText>
                                                </div>

                                            </MudStack>
                                        </MudCardContent>

                                    <MudCardActions Class="px-3 px-md-4 pb-3 pt-0 d-flex align-center justify-space-between flex-wrap">
                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Secondary"
                                                   StartIcon="@Icons.Material.Filled.Edit" OnClick="@(()=> EditPet(p))">
                                                Редактировать
                                            </MudButton>

                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Error"
                                                       StartIcon="@Icons.Material.Filled.Delete"
                                                   Class="mt-sm-0" OnClick="@(()=> DeletePetButton(p.PetId))">
                                                Удалить
                                            </MudButton>
                                        </MudCardActions>
                                    </MudCard>
                            </MudListItem>
                            
                            <MudDivider />
                        }
                    </MudList>
                }

            </MudPaper>

        </MudStack>
    </MudCard>

</MudContainer>

@code {
    private List<PetDto> ClientPets = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ClientPets = await PetsService.GetPetsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        isLoading = false;
    }

    async Task AddPet()
    {
        var parameters = new DialogParameters
    {
        { "IsEdit", false }
    };
        parameters.Add("Pet", new CreateUpdatePetDto
        {
            BirthDate = DateOnly.FromDateTime(DateTime.Today),
            GenderId = 0,
            SpeciesId = 0 
        });

        var dialog = await DialogService.ShowAsync<AddEditPetDialog>("Добавить питомца", parameters);

        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is CreateUpdatePetDto pet)
        {
            await PetsService.CreatePetAsync(pet);

            ClientPets = await PetsService.GetPetsAsync();
        }
    }

    async Task EditPet(PetDto petDto)
    {
        var parameters = new DialogParameters
    {
        { "IsEdit", true },
        { "Pet", new CreateUpdatePetDto
            {
                Name = petDto.Name,
                Breed = petDto.Breed,
                BirthDate = petDto.BirthDate,
                SpeciesId = petDto.SpeciesId,
                GenderId = petDto.GenderId
            }
        }
    };

        var dialog = await DialogService.ShowAsync<AddEditPetDialog>("Редактировать питомца", parameters);

        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is CreateUpdatePetDto pet)
        {
            await PetsService.UpdatePetAsync(petDto.PetId, pet);

            ClientPets = await PetsService.GetPetsAsync();
        }
    }

    private async Task DeletePetButton(int id)
    {
        var result = await DialogService.ShowMessageBox(
            "Удаление питомца",
            "Вы действительно хотите удалить питомца?",
            yesText: "Да",
            cancelText: "Нет",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (result != true)
            return;

        try
        {
            await PetsService.DeletePetAsync(id);

            Snackbar.Add("Питомец успешно удален", Severity.Success);

            ClientPets = await PetsService.GetPetsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка при отмене записи: {ex.Message}", Severity.Error);
        }
    }
}
<Page x:Class="VetSystemWpfDesktop.Pages.SchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local ="clr-namespace:VetSystemWpfDesktop.Converters"
      Background="#E3F2FD"
      Title="Расписание">
    <Page.Resources>
        <local:WorkdayTimeConverter x:Key="WorkdayTimeConverter"></local:WorkdayTimeConverter>
    </Page.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="8">
            <materialDesign:PackIcon Kind="Schedule" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Расписание" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>
        <Grid Margin="12" Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ КОЛОНКА -->
            <materialDesign:Card Grid.Column="0"
                             Padding="16"
                             UniformCornerRadius="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <!-- Поиск -->
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <TextBox Height="36" Width="200" materialDesign:HintAssist.Hint="Поиск..." Margin="0,0,0,10"/>
                    </StackPanel>

                    <!-- Список врачей -->
                    <ListView x:Name="DoctorsList"
                          BorderThickness="0"
                          Grid.Row="1"
                          HorizontalContentAlignment="Stretch" SelectionChanged="DoctorsList_SelectionChanged">

                        <ListView.ItemTemplate>

                            <DataTemplate>

                                <Border Padding="8">

                                    <StackPanel Orientation="Horizontal">

                                        <materialDesign:PackIcon
                                        Kind="Doctor"
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,6,0"
                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LastName}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding FirstName}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding MiddleName}"/>
                                        </StackPanel>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                </Grid>

            </materialDesign:Card>

            <!-- ПРАВАЯ КОЛОНКА -->

            <materialDesign:Card Grid.Column="2"
                     Padding="24"
                     UniformCornerRadius="16"
                     HorizontalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Заголовок карточки -->
                        <RowDefinition Height="Auto"/>
                        <!-- Заголовки колонок -->
                        <RowDefinition Height="*"/>
                        <!-- Список -->
                        <RowDefinition Height="Auto"/>
                        <!-- Кнопки -->
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Grid.Row="0"
                   Text="Шаблонное расписание"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

                    <!-- Заголовки колонок -->
                    <Grid Grid.Row="1" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                       
                        <TextBlock Grid.Column="1" Grid.ColumnSpan="3" Text="Рабочее время"
                       HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                        <TextBlock Grid.Column="4" Grid.ColumnSpan="3" Text="Обеденное время"
                       HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                    </Grid>

                    <!-- Список -->
                    <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      VerticalAlignment="Stretch">
                        <ItemsControl x:Name="ScheduleList"
                          FontSize="15"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6" Margin="0,4,0,4" Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding DayOfWeek}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                                            <TextBox Grid.Column="1" Height="34" Margin="4,0"
                                         Text="{Binding StartTime, Converter={StaticResource WorkdayTimeConverter}}"
                                         materialDesign:HintAssist.Hint="08:00" IsReadOnly="True"/>
                                            <TextBlock Grid.Column="2" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15"/>
                                            <TextBox Grid.Column="3" Height="34" Margin="4,0"
                                         Text="{Binding EndTime, Converter={StaticResource WorkdayTimeConverter}}"
                                         materialDesign:HintAssist.Hint="17:00" IsReadOnly="True"/>
                                            <TextBox Grid.Column="4" Height="34" Margin="12,0,0,0"
                                         Text="{Binding LunchStart, Converter={StaticResource WorkdayTimeConverter}}"
                                         materialDesign:HintAssist.Hint="12:00" IsReadOnly="True"/>
                                            <TextBlock Grid.Column="5" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15"/>
                                            <TextBox Grid.Column="6" Height="34" Margin="4,0"
                                         Text="{Binding LunchEnd, Converter={StaticResource WorkdayTimeConverter}}"
                                         materialDesign:HintAssist.Hint="13:00" IsReadOnly="True"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,24,0,0" VerticalAlignment="Bottom">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" Foreground="White" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil"/>
                                <TextBlock Text="Редактировать шаблон" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarRemove"/>
                                <TextBlock Text="Добавить исключение" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </Grid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</Page>
@page "/dashboard"
@using MudBlazor
@using VetSystemModels.Dto.Appointment
@using VetSystemModels.Dto.Client
@inject Services.AppointmentsService AppointmentsService
@inject Services.ClientsService ClientsService
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.False" Class="pt-2 px-4"
              Style="background: linear-gradient(109.6deg, #E3F2FD 0%, #BBDEFB 100%); min-height:100vh;">

    <!-- ВЕРХНИЙ БАР -->
    <MudCard Elevation="2" Class="d-flex justify-end align-center p-4 mt-1" Style="border-radius:16px;">
        <MudStack Direction="Row" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Large" Color="Color.Primary"/>
            <MudText Typo="Typo.h6" Class="ml-2">@Client.LastName @Client.FirstName</MudText>
        </MudStack>
    </MudCard>

    <!-- ОСНОВНАЯ КАРТОЧКА -->
    <MudCard Elevation="2" Class="p-6 mt-4" Style="border-radius:16px;">
        <MudStack Spacing="3">

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="mx-4 mt-4">
                Создать запись на приём
            </MudButton>

            <MudText Typo="Typo.h6" Class="ml-6">
                Ваши записи
            </MudText>

            <MudPaper Elevation="0"
                      Class="mx-4 mb-4"
                      Style="background:#E3F2FD; border-radius:12px;">

                @if (isLoading)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary"/>
                }
                else if (Appointments.Count == 0)
                {
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Info">
                        Нет записей.
                    </MudText>
                }
                else
                {
                    <MudList T="AppointmentDto" Dense="true">
                        @foreach (var appointment in Appointments)
                        {
                            <MudListItem>
                                <MudCard Elevation="1"
                                         Outlined="false"
                                         Class="mb-2 mt-2"
                                         Style="border-radius: 12px; overflow: hidden;">

                                    <MudCardContent Class="pa-4">
                                        <MudStack Spacing="2">

                                            <!-- Верхняя строка: Питомец + статус (если есть) -->
                                            <div class="d-flex align-center justify-space-between flex-wrap">
                                                <div class="d-flex align-center flex-wrap">
                                                    <MudIcon Icon="@Icons.Material.Filled.Pets"
                                                             Size="Size.Small"
                                                             Color="Color.Primary"
                                                             Class="mr-3" />
                                                    <MudText Typo="Typo.h6" Class="fw-semibold mb-0">
                                                        @appointment.PetName
                                                    </MudText>
                                                </div>
                                                <MudChip Color="@GetStatusColor(appointment.AppointmentStatusName)"
                                                         Variant="Variant.Filled"
                                                         Size="Size.Small"
                                                         Class="fw-semibold">
                                                    @appointment.AppointmentStatusName
                                                </MudChip>
                                            </div>

                                            <!-- Услуга -->
                                            <MudText Typo="Typo.subtitle1">
                                                @appointment.ServiceName
                                            </MudText>

                                            <!-- Дата и время -->
                                            <div class="d-flex align-center gap-4">
                                                <div class="d-flex align-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday"
                                                             Size="Size.Small"
                                                             Color="Color.Default"
                                                             Class="mr-2" />
                                                    <MudText Size="Size.Small">
                                                        @appointment.AppointmentDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))
                                                    </MudText>
                                                </div>

                                                <div class="d-flex align-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.AccessTime"
                                                             Size="Size.Small"
                                                             Color="Color.Default"
                                                             Class="mr-2" />
                                                    <MudText Size="Size.Small">
                                                        @appointment.StartTime — @appointment.EndTime
                                                    </MudText>
                                                </div>
                                            </div>

                                        </MudStack>
                                    </MudCardContent>

                                    <MudCardActions Class="px-4 pb-4 pt-0">
                                        @* <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Visibility">
                                            Подробнее
                                        </MudButton>
 *@
                                        @if (appointment.AppointmentDate >= DateOnly.FromDateTime(DateTime.Now))
                                        {
                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Error"
                                                       StartIcon="@Icons.Material.Filled.EventBusy"
                                                       Class="ml-auto">
                                                Отменить
                                            </MudButton>
                                        }
                                    </MudCardActions>
                                </MudCard>
                            </MudListItem>

                            <MudDivider/>
                        }
                    </MudList>
                }

            </MudPaper>

        </MudStack>
    </MudCard>

</MudContainer>

@code {

    private List<AppointmentDto> Appointments = new();
    private ClientDto Client = new();
    private bool isLoading = true;

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Завершен" => Color.Success,        
            "Отменен" => Color.Error,          
            "В процессе" => Color.Info,       
            "Запланирован" => Color.Info,     
            "Ожидает" => Color.Warning,     
            _ => Color.Default
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Appointments = await AppointmentsService.GetAppointmentsByClientIdAsync();
            Client = await ClientsService.GetClientByUserIdAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }

        isLoading = false;
    }

}
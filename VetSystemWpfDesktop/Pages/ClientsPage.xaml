<Page x:Class="VetSystemWpfDesktop.Pages.ClientsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
      Background="#E3F2FD" Title="Клиенты">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="8">
            <materialDesign:PackIcon Kind="Account" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Клиенты" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <materialDesign:Card Margin="4" Padding="16" UniformCornerRadius="12">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Account" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="Всего клиентов" Margin="0,6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="0" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Name="AllClientsTextBlock"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
  
        <materialDesign:Card Grid.Row="2" Padding="18" UniformCornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
    
                <DockPanel Margin="0,0,0,14">
                    <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignRaisedButton}" Foreground="White" Height="36" Click="AddClientButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus"/>
                            <TextBlock Text="Добавить клиента" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
          
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <TextBox Width="200" Height="36" materialDesign:HintAssist.Hint="Поиск..."/>
                    </StackPanel>
                </DockPanel>
          
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
            
                    <Grid Margin="8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Фамилия" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Имя" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Отчество" Grid.Column="2" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Дата рождения" Grid.Column="3" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Телефон" Grid.Column="4" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="Действия" Grid.Column="5" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                 
                    <ListView Grid.Row="1" x:Name="ClientsListView" BorderThickness="0" HorizontalContentAlignment="Stretch" materialDesign:ElevationAssist.Elevation="Dp0">
                     
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd" Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <Grid Margin="8,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="250"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">

                                            <materialDesign:PackIcon Kind="Account"
                             Margin="0,0,6,0"
                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

                                            <TextBlock Text="{Binding LastName}"
               FontWeight="SemiBold" VerticalAlignment="Center"/>

                                        </StackPanel>
                                        <TextBlock Text="{Binding FirstName}" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding MiddleName}" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding BirthDate, StringFormat='dd.MM.yyyy'}" Grid.Column="3" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Phone}" Grid.Column="4" VerticalAlignment="Center"/>
                                 
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Просмотреть">
                                                <materialDesign:PackIcon Kind="EyeOutline"/>
                                            </Button>
                                            <Button>

                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">

                                                    
                                                        <Setter Property="IsEnabled" Value="False"/>

                                                        <Style.Triggers>
                                                 
                                                            <DataTrigger Binding="{Binding UserId}" Value="{x:Null}">
                                                                <Setter Property="IsEnabled" Value="True"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>

                                                    </Style>
                                                </Button.Style>

                                                <materialDesign:PackIcon Kind="Pencil"/>

                                            </Button>
                                            <Button>

                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">

                                                        <Setter Property="IsEnabled" Value="False"/>

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UserId}" Value="{x:Null}">
                                                                <Setter Property="IsEnabled" Value="True"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>

                                                    </Style>

                                                </Button.Style>

                                                <materialDesign:PackIcon Kind="Delete"/>

                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Питомцы">
                                                <materialDesign:PackIcon Kind="Dog"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="История">
                                                <materialDesign:PackIcon Kind="History"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
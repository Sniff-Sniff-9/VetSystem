<Page x:Class="VetSystemWpfDesktop.Pages.ClientEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#E3F2FD"
      Title="Клиент">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="8,8,8,18">

            <materialDesign:PackIcon
                Kind="Account"
                Width="40"
                Height="40"
                Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

            <TextBlock
                Text="Клиент"
                FontSize="30"
                FontWeight="SemiBold"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

        </StackPanel>


        <!-- MAIN CARD -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <materialDesign:Card
                Padding="18"
                Margin="0,0,0,10"
                UniformCornerRadius="16"
                materialDesign:ElevationAssist.Elevation="Dp2">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>


                    <!-- BLOCK: Основная информация -->

                    <TextBlock
                        Text="Основная информация"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,0,0,16"/>


                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>


                        <!-- Фамилия -->

                        <materialDesign:Card
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="8"
                            Padding="16"
                            UniformCornerRadius="10"
                            materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                    Text="Фамилия"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,6"/>

                                <TextBox
                                    Height="36"
                                    materialDesign:HintAssist.Hint="Введите фамилию" Name="LastNameTextBox"
                                    Text="{Binding LastName}"/>

                            </StackPanel>

                        </materialDesign:Card>


                        <!-- Имя -->

                        <materialDesign:Card
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="8"
                            Padding="16"
                            UniformCornerRadius="10"
                            materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                    Text="Имя"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,6"/>

                                <TextBox
                                    Height="36"
                                    materialDesign:HintAssist.Hint="Введите имя" Name="FirstNameTextBox"
                                    Text="{Binding FirstName}"/>

                            </StackPanel>

                        </materialDesign:Card>


                        <!-- Отчество -->

                        <materialDesign:Card
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="8"
                            Padding="16"
                            UniformCornerRadius="10"
                            materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                    Text="Отчество"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,6"/>

                                <TextBox
                                    Height="36"
                                    materialDesign:HintAssist.Hint="Введите отчество" Name="MiddleNameTextBox"
                                    Text="{Binding MiddleName}"/>

                            </StackPanel>

                        </materialDesign:Card>


                        <!-- Телефон -->

                        <materialDesign:Card
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="8"
                            Padding="16"
                            UniformCornerRadius="10"
                            materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                    Text="Телефон"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,6"/>

                                <TextBox
                                    Height="36"
                                    materialDesign:HintAssist.Hint="Введите телефон" Name="PhoneTextBox"
                                    Text="{Binding Phone}"/>

                            </StackPanel>

                        </materialDesign:Card>

                        <materialDesign:Card
                                            Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Margin="8"
                                            Padding="16"
                                            UniformCornerRadius="10"
                                            materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                            Text="Дата рождения"
                                            FontWeight="SemiBold"
                                            Margin="0,0,0,6"/>

                                <DatePicker
                                            Height="36"
                                            materialDesign:HintAssist.Hint="Выберите дату" Name="BirthDateDatePicker"/>

                            </StackPanel>

                        </materialDesign:Card>


                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="Новый питомец"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,20,0,16"/>

                    <Grid Grid.Row="3">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>


                        <!-- Имя питомца -->

                        <materialDesign:Card
        Grid.Row="0"
        Grid.Column="0"
        Margin="8"
        Padding="16"
        UniformCornerRadius="10"
        materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                            Text="Имя питомца"
                                            FontWeight="SemiBold"
                                            Margin="0,0,0,6"/>

                                <TextBox
                Height="36"
                materialDesign:HintAssist.Hint="Введите имя" Name="PetNameTextBox"/>

                            </StackPanel>

                        </materialDesign:Card>


                        <!-- Вид -->

                        <materialDesign:Card
        Grid.Row="0"
        Grid.Column="1"
        Margin="8"
        Padding="16"
        UniformCornerRadius="10"
        materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                Text="Вид"
                FontWeight="SemiBold"
                Margin="0,0,0,6"/>

                                <ComboBox
                Height="36"
                materialDesign:HintAssist.Hint="Выберите вид" Name="SpeciesComboBox"/>

                            </StackPanel>

                        </materialDesign:Card>


                        <!-- Порода -->

                        <materialDesign:Card
        Grid.Row="1"
        Grid.Column="0"
        Margin="8"
        Padding="16"
        UniformCornerRadius="10"
        materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                Text="Порода"
                FontWeight="SemiBold"
                Margin="0,0,0,6"/>

                                <TextBox
                Height="36"
                materialDesign:HintAssist.Hint="Введите породу" Name="BreedTextBox"/>

                            </StackPanel>

                        </materialDesign:Card>


                        <!-- Пол -->

                        <materialDesign:Card Grid.Row="1"
                                                Grid.Column="1"
                                                Margin="8"
                                                Padding="16"
                                                UniformCornerRadius="10"
                                                materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                        Text="Пол"
                                        FontWeight="SemiBold"
                                        Margin="0,0,0,6"/>

                                <ComboBox
                                        Height="36"
                                        materialDesign:HintAssist.Hint="Выберите пол" Name="GenderComboBox"/>         

                            </StackPanel>

                        </materialDesign:Card>


                        <!-- Дата рождения -->

                        <materialDesign:Card
                                        Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Margin="8"
                                        Padding="16"
                                        UniformCornerRadius="10"
                                        materialDesign:ElevationAssist.Elevation="Dp0">

                            <StackPanel>

                                <TextBlock
                                        Text="Дата рождения"
                                        FontWeight="SemiBold"
                                        Margin="0,0,0,6"/>

                                <DatePicker
                                        Height="36"
                                        materialDesign:HintAssist.Hint="Выберите дату" Name="PetBirthDatePicker"/>

                            </StackPanel>

                        </materialDesign:Card>

                    </Grid>
                    <!-- BUTTONS -->

                    <StackPanel
                        Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                        <Button
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,10,0"
                            Width="120"
                            Click="CancelButton_Click">

                            Отмена

                        </Button>


                        <Button
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Foreground="White"
                            Width="140"
                            Click="SaveButton_Click">

                            Сохранить

                        </Button>

                    </StackPanel>

                </Grid>

            </materialDesign:Card>

        </ScrollViewer>

    </Grid>

</Page>
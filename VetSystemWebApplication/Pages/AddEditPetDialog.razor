@using MudBlazor
@using VetSystemModels.Dto.Pet
@using VetSystemModels.Entities
@using VetSystemWebApplication.Services
@inject PetsService PetsService
@inject ISnackbar Snackbar

<MudDialog Class="pet-dialog">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="pb-0">
            @(IsEdit ? "Редактировать питомца" : "Добавить питомца")
        </MudText>
    </TitleContent>
    <DialogContent>

        <MudForm @ref="form">
            <MudStack Spacing="4" Class="mb-6">

                <MudTextField Label="Имя"
                              @bind-Value="Pet.Name"
                              Required="true" />

                <MudTextField Label="Порода" Required="true"
                              @bind-Value="Pet.Breed" />

                <MudSelect T="int"
                           Label="Вид"
                           @bind-Value="Pet.SpeciesId"
                           Required="true">

                    <MudSelectItem T="int" Value="0" Disabled="true">
                        Выберите вид
                    </MudSelectItem>

                    @foreach (var species in Species)
                    {
                        <MudSelectItem T="int" Value="@species.SpeciesId">
                            @species.SpeciesName
                        </MudSelectItem>
                    }

                </MudSelect>

                <MudSelect T="int"
                           Label="Пол"
                           @bind-Value="Pet.GenderId"
                           Required="true">

                    <MudSelectItem T="int" Value="0" Disabled="true">
                        Выберите пол
                    </MudSelectItem>

                    @foreach (var gender in Genders)
                    {
                        <MudSelectItem T="int" Value="@gender.GenderId">
                            @gender.GenderName
                        </MudSelectItem>
                    }

                </MudSelect>

                <MudDatePicker Label="Дата рождения"
                               @bind-Date="BirthDate"
                               MaxDate="@DateTime.Today" />

            </MudStack>
        </MudForm>

    </DialogContent>

    <DialogActions>

        <MudButton Color="Color.Default"
                   OnClick="Cancel">
            Отмена
        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="@Save">
            @(IsEdit ? "Сохранить" : "Добавить")
        </MudButton>

    </DialogActions>

</MudDialog>

<style>
    .pet-dialog .mud-dialog-title {
        padding-bottom: 8px;
    }

    .pet-dialog .mud-dialog-actions {
        padding: 0 24px 16px 24px;
    }
</style>

@code {
    MudForm? form;

    private DateTime? BirthDate
    {
        get => Pet.BirthDate.ToDateTime(TimeOnly.MinValue) ;
    set
        {
            if (value.HasValue)
                Pet.BirthDate = DateOnly.FromDateTime(value.Value);
        }
    }

    [CascadingParameter]
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public CreateUpdatePetDto Pet { get; set; } = new();

    public List<Species> Species = new();

    public List<Gender> Genders = new();

    [Parameter]
    public bool IsEdit { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Species = await PetsService.GetSpeciesAsync();
        Genders = await PetsService.GetGendersAsync();
        StateHasChanged();
    }

    void Cancel()
    {
        MudDialog?.Cancel();
    }

    async Task Save()
    {
        try
        {
            await form!.Validate();

            if (!form.IsValid || Pet.SpeciesId == 0 || Pet.GenderId == 0)
            {
                Snackbar.Add("Заполните все поля", Severity.Error);
                return;
            }

            MudDialog?.Close(DialogResult.Ok(Pet));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
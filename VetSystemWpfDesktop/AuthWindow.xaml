<Window x:Class="VetSystemWpfDesktop.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:VetSystemWpfDesktop"
        mc:Ignorable="d"
        Title="Ветеринарная Система" Height="450" Width="800" ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <Grid>
        <Grid>


            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E3F2FD" Offset="0"/>
                        <GradientStop Color="#BBDEFB" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>


                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Paw"
                                         Width="100"
                                         Height="100"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="32"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Text="Ветеринарная"/>
                    <TextBlock FontSize="32"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Text="Система"/>
                </StackPanel>
            </Grid>


            <Grid Grid.Column="1">
                <materialDesign:Card Width="380"
                                 Padding="36"
                                 Background="{DynamicResource MaterialDesign.Brush.Surface}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 UniformCornerRadius="24"
                                 materialDesign:ElevationAssist.Elevation="Dp6">

                    <StackPanel>

                        <TextBlock Text="Вход"
                               FontSize="28"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                               Margin="0,0,0,24"/>


                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Эл. почта"
                             FontSize="16"
                             Margin="0,0,0,16" materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"/>


                        <PasswordBox Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 materialDesign:HintAssist.Hint="Пароль"
                                 FontSize="16"  
                                 Margin="0,0,0,28"
                                 materialDesign:TextFieldAssist.LeadingIcon="LockOutline"></PasswordBox>


                        <Button Content="Войти"
                            Height="52"
                            FontSize="16"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Margin="0,0,0,12" Click="Button_Click"/>


                        <Button Content="Забыли пароль?"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="0,5,0,0"
                            Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                            HorizontalAlignment="Center"
                            FontWeight="Medium"/>

                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>

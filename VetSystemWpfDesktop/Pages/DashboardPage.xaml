<Page x:Class="VetSystemWpfDesktop.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:local="clr-namespace:VetSystemWpfDesktop.Converters"
      Background="#E3F2FD"
      Title="Панель управления">


    <Page.Resources>
        <local:AppointmentNowConverter x:Key="AppointmentNowConverter"/>

        <Style x:Key="StatusChip" TargetType="Border">

            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="TextElement.Foreground" Value="#424242"/>

            <Style.Triggers>

          
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Завершен">
                    <Setter Property="Background" Value="#334CAF50"/>
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                    <Setter Property="TextElement.Foreground" Value="#2E7D32"/>
                </DataTrigger>

            
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Отменен">
                    <Setter Property="Background" Value="#33F44336"/>
                    <Setter Property="BorderBrush" Value="#F44336"/>
                    <Setter Property="TextElement.Foreground" Value="#C62828"/>
                </DataTrigger>

           
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="В процессе">
                    <Setter Property="Background" Value="#332196F3"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="TextElement.Foreground" Value="#1565C0"/>
                </DataTrigger>

         
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Запланирован">
                    <Setter Property="Background" Value="#332196F3"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="TextElement.Foreground" Value="#1565C0"/>
                </DataTrigger>

          
                <DataTrigger Binding="{Binding AppointmentStatusName}" Value="Ожидает">
                    <Setter Property="Background" Value="#33FFC107"/>
                    <Setter Property="BorderBrush" Value="#FFC107"/>
                    <Setter Property="TextElement.Foreground" Value="#F57F17"/>
                </DataTrigger>

            </Style.Triggers>

        </Style>
 
        <Style x:Key="KpiCard" TargetType="materialDesign:Card">
            <Setter Property="Padding" Value="24"/>
            <Setter Property="UniformCornerRadius" Value="20"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3"/>
        </Style>
    </Page.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>
        
            <RowDefinition Height="Auto"/>
            
            <RowDefinition Height="*"/>
   
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal" Margin="8">
            <materialDesign:PackIcon Kind="ViewDashboard" Width="40" Height="40" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <TextBlock Text="Главная" FontSize="30" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>

       
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <materialDesign:Card Margin="4" Padding="16" UniformCornerRadius="12">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CurrencyRub" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="Доход за месяц" Margin="0,6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding IncomePerMonth, StringFormat='{}{0} ₽'}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="4" Padding="16" UniformCornerRadius="12" Grid.Column="1">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarCheck" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="Приемов сегодня" Margin="0,6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TodayAppointmentsCount}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="4" Padding="16" UniformCornerRadius="12" Grid.Column="2">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="ChartLine" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="Загруженность сегодня" Margin="0,6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding WorkloadPercent, StringFormat='{}{0:P0}'}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>


        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Margin="4" Padding="16" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Быстрые действия" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <StackPanel VerticalAlignment="Center" Grid.Row="1">
                        <Button Height="52" Margin="0,0,0,12" Name="CreateAppointmentButton" Click="CreateAppointmentButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Plus" Foreground="White"/>
                                <materialDesign:PackIcon Kind="CalendarClock" Foreground="White"/>
                                <TextBlock Text="Новая запись" Margin="10,0,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>
                        <Button Height="52" Margin="0,0,0,12" Name="CreateClientButton" Click="CreateClientButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Plus" Foreground="White"/>
                                <materialDesign:PackIcon Kind="Account" Foreground="White"/>
                                <TextBlock Text="Новый клиент" Margin="10,0,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>
                        <Button Height="52" Name="CreatePetButton" Click="CreatePetButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Plus" Foreground="White"/>
                                <materialDesign:PackIcon Kind="Dog" Foreground="White"/>
                                <TextBlock Text="Новый питомец" Margin="10,0,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

     
            <materialDesign:Card Grid.Column="1" Margin="4" Padding="16" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Недельная нагрузка" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <lvc:CartesianChart Series="{Binding ClinicLoadSeries}" Height="200">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis  Labels="{Binding ClinicLoadLabels}"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis  MinValue="0"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </StackPanel>
            </materialDesign:Card>
        </Grid>


        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="16" UniformCornerRadius="12" Margin="4">
                <StackPanel>
                    <TextBlock Text="Ближайшие приемы" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                           
                            <Grid Margin="8,0,8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Дата" FontWeight="SemiBold"/>
                                <TextBlock Text="Начало" Grid.Column="1" FontWeight="SemiBold"/>
                                <TextBlock Text="Услуга" Grid.Column="2" FontWeight="SemiBold"/>
                                <TextBlock Text="Специалист" Grid.Column="3" FontWeight="SemiBold"/>
                                <TextBlock Text="Питомец" Grid.Column="4" FontWeight="SemiBold"/>
                                <TextBlock Text="Статус" Grid.Column="5" FontWeight="SemiBold" />
                            </Grid>

                          
                            <ListView x:Name="AppointmentsNearListView"
                          BorderThickness="0"
                          HorizontalContentAlignment="Stretch"
                          materialDesign:ElevationAssist.Elevation="Dp0" Grid.Row="1"
                          ItemsSource="{Binding AppointmentsNear}">

                              
                                <ListView.Style>
                                    <Style TargetType="ListView">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListView">
                                                            <TextBlock Text="Нет записей."
                                                         
                                                           Foreground="Gray"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="0,50,0,0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Style>

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border x:Name="RowBorder" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Background="Transparent">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="RowBorder" Property="Background" Value="#F5F5F5"/>
                                                        </Trigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource AppointmentNowConverter}">
                                                                    <Binding Path="AppointmentDate"/>
                                                                    <Binding Path="SсheduleTimeStart"/>
                                                                    <Binding Path="SсheduleTimeEnd"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter TargetName="RowBorder" Property="Background" Value="#E3F2FD"/>
                                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="#2196F3"/>
                                                            <Setter TargetName="RowBorder" Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>

                           
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                            <Grid Margin="8,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat=dd.MM.yyyy}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding StartTime, StringFormat=HH:mm}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding ServiceName}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding EmployeeName}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" Text="{Binding PetName}" VerticalAlignment="Center"/>
                                                <Border Grid.Column="5" Style="{StaticResource StatusChip}" HorizontalAlignment="Left" Height="30">
                                                    <TextBlock Text="{Binding AppointmentStatusName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>

                            </ListView>
                        </Grid>
                    </ScrollViewer>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1"
                     Padding="16"
                     UniformCornerRadius="12"
                     Margin="4">

       
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel>
               
                        <TextBlock Text="Ожидают подтверждения"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

                        
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                
                                <Grid Margin="8,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Дата" FontWeight="SemiBold"/>
                                    <TextBlock Text="Начало" Grid.Column="1" FontWeight="SemiBold"/>
                                    <TextBlock Text="Услуга" Grid.Column="2" FontWeight="SemiBold"/>
                                    <TextBlock Text="Специалист" Grid.Column="3" FontWeight="SemiBold"/>
                                    <TextBlock Text="Питомец" Grid.Column="4" FontWeight="SemiBold"/>
                                    <TextBlock Text="Действие" Grid.Column="5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </Grid>

                     
                                <ListView Grid.Row="1" x:Name="AppointmentsExpectListView" BorderThickness="0" HorizontalContentAlignment="Stretch"
                                          materialDesign:ElevationAssist.Elevation="Dp0" ItemsSource="{Binding AppointmentsExpect}">
                                    <ListView.Style>
                                        <Style TargetType="ListView">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListView">
                                                                <TextBlock Text="Нет записей."
                         
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,50,0,0"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.Style>
                                    <ListView.ItemContainerStyle>

                                        <Style TargetType="ListViewItem">
                                           
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                                            <Setter Property="Template">

                                                <Setter.Value>

                                                    <ControlTemplate TargetType="ListViewItem">

                                                        <Border x:Name="RowBorder"
            BorderBrush="#E0E0E0"
            BorderThickness="0,0,0,1"
            Background="Transparent">

                                                            <ContentPresenter/>

                                                        </Border>

                                                        <ControlTemplate.Triggers>

                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="RowBorder"
                    Property="Background"
                    Value="#F5F5F5"/>
                                                            </Trigger>

                                                      
                                                            <DataTrigger Value="True">

                                                                <DataTrigger.Binding>

                                                                    <MultiBinding Converter="{StaticResource AppointmentNowConverter}">

                                                                        <Binding Path="AppointmentDate"/>
                                                                        <Binding Path="SсheduleTimeStart"/>
                                                                        <Binding Path="SсheduleTimeEnd"/>

                                                                    </MultiBinding>

                                                                </DataTrigger.Binding>

                                                                <Setter TargetName="RowBorder"
                                                                        Property="Background"
                                                                        Value="#E3F2FD"/>

                                                                <Setter TargetName="RowBorder"
                                                                        Property="BorderBrush"
                                                                        Value="#2196F3"/>

                                                                <Setter TargetName="RowBorder"
                                                                        Property="BorderThickness"
                                                                        Value="2"/>

                                                            </DataTrigger>

                                                        </ControlTemplate.Triggers>

                                                    </ControlTemplate>

                                                </Setter.Value>

                                            </Setter>

                                        </Style>

                                    </ListView.ItemContainerStyle>

                               
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                                <Grid Margin="8,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="3*"/>
                                                        <ColumnDefinition Width="3*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding AppointmentDate, StringFormat=dd.MM.yyyy}" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="1" Text="{Binding StartTime, StringFormat=HH:mm}" VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="2" Text="{Binding ServiceName}" VerticalAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Left"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding EmployeeName}" VerticalAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Left"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding PetName}" VerticalAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Left"/>
                                                    <StackPanel Orientation="Horizontal" Grid.Column="5">
                                                         <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Подтвердить"  
                                                            Name="AcceptButton" Click="AcceptButton_Click"
                                                            HorizontalAlignment="Center">
                                                        <materialDesign:PackIcon Kind="Check"/>
                                                    </Button>
                                                         <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Подтвердить"  
                                                            Name="RejectButton" Click="RejectButton_Click"
                                                            HorizontalAlignment="Center">
                                                        <materialDesign:PackIcon Kind="Close"/>
                                                    </Button>
                                                    </StackPanel>
                                                   
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </ScrollViewer>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
            <materialDesign:Snackbar Grid.Row="3" Grid.Column="1" 
                                 x:Name="MainSnackbar"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Bottom"
                                 Margin="20"
                                 CornerRadius="12"
                                 Background="{StaticResource MaterialDesign.Brush.Primary}"
                                 MessageQueue="{Binding MainSnackbarMessageQueue}">
            </materialDesign:Snackbar>
        </Grid>

    </Grid>
</Page>